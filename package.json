{
  "name": "insighta-cli",
  "version": "1.0.0",
  "description": "Insighta Labs+ CLI — interact with the Profile Intelligence API",
  "main": "dist/index.js",
  "bin": {
    "insighta": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "keywords": ["insighta", "cli", "profiles"],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.8",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "commander": "^12.0.0",
    "open": "^8.4.2",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.25",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2",
    "vitest": "^1.4.0"
  }
}
